{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poe-build-research.local/schemas/data/poe_ninja_build_listing.schema.json",
  "title": "PoENinjaBuildListing",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "source",
    "leagues",
    "freshness",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "record_kind": {
      "type": "string",
      "const": "poe_ninja_build_listing"
    },
    "source": {
      "$ref": "#/$defs/source_surface"
    },
    "leagues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/league_entry"
      }
    },
    "freshness": {
      "$ref": "#/$defs/freshness"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "source_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "upstream_system",
        "public_surface",
        "site_base_url"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "const": "poe_ninja_public_builds"
        },
        "upstream_system": {
          "type": "string",
          "const": "poe_ninja_public_builds"
        },
        "public_surface": {
          "type": "string",
          "const": "build_listing"
        },
        "site_base_url": {
          "type": "string",
          "const": "https://poe.ninja"
        }
      }
    },
    "league_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "league_name",
        "league_url",
        "display_name",
        "source_bucket",
        "status_code",
        "total_characters",
        "top_archetypes",
        "search_page_url",
        "snapshot_candidates"
      ],
      "properties": {
        "league_name": {
          "type": "string",
          "minLength": 1
        },
        "league_url": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "source_bucket": {
          "type": "string",
          "enum": [
            "current",
            "archived",
            "unresolved"
          ]
        },
        "status_code": {
          "type": "integer",
          "minimum": 0
        },
        "total_characters": {
          "type": "integer",
          "minimum": 0
        },
        "top_archetypes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/top_archetype"
          }
        },
        "search_page_url": {
          "type": "string",
          "format": "uri"
        },
        "snapshot_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/snapshot_candidate"
          }
        }
      }
    },
    "top_archetype": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class_name",
        "skill_name",
        "usage_percent",
        "trend"
      ],
      "properties": {
        "class_name": {
          "type": "string",
          "minLength": 1
        },
        "skill_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "usage_percent": {
          "type": "number",
          "minimum": 0
        },
        "trend": {
          "type": "integer"
        }
      }
    },
    "snapshot_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "league_url",
        "snapshot_type",
        "league_name",
        "time_machine_labels",
        "version",
        "snapshot_name",
        "overview_type",
        "passive_tree",
        "atlas_tree"
      ],
      "properties": {
        "league_url": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_type": {
          "type": "string",
          "minLength": 1
        },
        "league_name": {
          "type": "string",
          "minLength": 1
        },
        "time_machine_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_name": {
          "type": "string",
          "minLength": 1
        },
        "overview_type": {
          "type": "integer",
          "minimum": 0
        },
        "passive_tree": {
          "type": "string",
          "minLength": 1
        },
        "atlas_tree": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retrieved_at",
        "resources",
        "observed_data_timestamps"
      ],
      "properties": {
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/resource_freshness"
          }
        },
        "observed_data_timestamps": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "resource_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "method",
        "content_type",
        "age_seconds",
        "last_modified",
        "cf_cache_status",
        "max_age_seconds",
        "stale_while_revalidate_seconds",
        "stale_if_error_seconds"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "method": {
          "type": "string",
          "const": "GET"
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "age_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "last_modified": {
          "type": [
            "string",
            "null"
          ]
        },
        "cf_cache_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "max_age_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "stale_while_revalidate_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "stale_if_error_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generator",
        "upstream_system",
        "inputs",
        "notes"
      ],
      "properties": {
        "generator": {
          "type": "string",
          "const": "poe_build_research.data.poe_ninja"
        },
        "upstream_system": {
          "type": "string",
          "const": "poe_ninja_public_builds"
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/provenance_input"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "provenance_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "method",
        "status",
        "content_type",
        "etag",
        "body_sha256",
        "body_bytes",
        "fetched_at"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "method": {
          "type": "string",
          "const": "GET"
        },
        "status": {
          "type": "integer",
          "minimum": 200
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "etag": {
          "type": [
            "string",
            "null"
          ]
        },
        "body_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "body_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "fetched_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
