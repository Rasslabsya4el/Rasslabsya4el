{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poe-build-research.local/schemas/pob/pob.skill-requirements.schema.json",
  "title": "PoB skill requirements",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "query",
    "skill_identity",
    "source_refs",
    "hard_requirements",
    "derived_axes",
    "support_concerns_pending_pob_proof",
    "unknowns_or_unsupported_fields",
    "forbidden_decision_outputs_absent",
    "publication_outputs_absent"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "record_kind": {
      "type": "string",
      "const": "pob_skill_requirements"
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input",
        "normalized",
        "resolution"
      ],
      "properties": {
        "input": {
          "$ref": "#/$defs/non_empty_string"
        },
        "normalized": {
          "$ref": "#/$defs/non_empty_string"
        },
        "resolution": {
          "type": "string",
          "const": "pinned_pob_skill_definition"
        }
      }
    },
    "skill_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skill_id",
        "variant_id",
        "name",
        "base_type_name",
        "gem_family",
        "record_id",
        "game_id",
        "granted_effect_id",
        "secondary_granted_effect_id",
        "source_file",
        "source_line"
      ],
      "properties": {
        "skill_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "variant_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "base_type_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "gem_family": {
          "type": "string",
          "enum": [
            "active_gems",
            "support_gems",
            "unknown"
          ]
        },
        "record_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "game_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "granted_effect_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "secondary_granted_effect_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_file": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_line": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "hard_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tags",
        "tag_facets",
        "skill_types",
        "base_flags",
        "weapon_types",
        "legal_weapon_offhand_families",
        "legality_flags",
        "requirements",
        "cost_and_reservation",
        "stat_ids",
        "notable_restrictions"
      ],
      "properties": {
        "tags": {
          "$ref": "#/$defs/stateful_values"
        },
        "tag_facets": {
          "type": "object"
        },
        "skill_types": {
          "$ref": "#/$defs/stateful_values"
        },
        "base_flags": {
          "$ref": "#/$defs/stateful_values"
        },
        "weapon_types": {
          "$ref": "#/$defs/stateful_values"
        },
        "legal_weapon_offhand_families": {
          "$ref": "#/$defs/stateful_values"
        },
        "legality_flags": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "state",
            "flags",
            "evidence"
          ],
          "properties": {
            "state": {
              "type": "string",
              "const": "known"
            },
            "flags": {
              "type": "object",
              "additionalProperties": {
                "type": "boolean"
              }
            },
            "evidence": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/string_array"
              }
            }
          }
        },
        "requirements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "attributes",
            "levels"
          ],
          "properties": {
            "attributes": {
              "type": "object"
            },
            "levels": {
              "type": "object"
            }
          }
        },
        "cost_and_reservation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "costs",
            "reservation"
          ],
          "properties": {
            "costs": {
              "type": "object"
            },
            "reservation": {
              "type": "object"
            }
          }
        },
        "stat_ids": {
          "$ref": "#/$defs/string_array"
        },
        "notable_restrictions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "derived_axes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "possible_delivery_axes",
        "possible_damage_axes",
        "possible_resource_axes",
        "possible_item_defense_base_families"
      ],
      "properties": {
        "possible_delivery_axes": {
          "$ref": "#/$defs/string_array"
        },
        "possible_damage_axes": {
          "$ref": "#/$defs/string_array"
        },
        "possible_resource_axes": {
          "$ref": "#/$defs/string_array"
        },
        "possible_item_defense_base_families": {
          "type": "object"
        }
      }
    },
    "support_concerns_pending_pob_proof": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "unknowns_or_unsupported_fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "state",
          "reason"
        ],
        "properties": {
          "field": {
            "$ref": "#/$defs/non_empty_string"
          },
          "state": {
            "type": "string",
            "enum": [
              "unknown",
              "unsupported"
            ]
          },
          "reason": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "forbidden_decision_outputs_absent": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean",
        "const": false
      },
      "minProperties": 7
    },
    "publication_outputs_absent": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "stateful_values": {
      "type": "object",
      "required": [
        "state",
        "values"
      ],
      "properties": {
        "state": {
          "$ref": "#/$defs/non_empty_string"
        },
        "values": {
          "$ref": "#/$defs/string_array"
        },
        "unsupported_reason": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_field": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "source_kind",
        "locator",
        "line",
        "sha256",
        "authority_role",
        "summary"
      ],
      "properties": {
        "ref_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "locator": {
          "$ref": "#/$defs/non_empty_string"
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "authority_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
