{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/pob/pob.game-corpus-manifest.schema.json",
  "title": "PoB game corpus manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "corpus_id",
    "source_lane",
    "families",
    "downstream_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "corpus_id": {
      "type": "string",
      "const": "pob_game_corpus"
    },
    "source_lane": {
      "$ref": "#/$defs/source_lane"
    },
    "families": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/family_summary"
      }
    },
    "downstream_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_root",
        "runtime_authority",
        "consumer_rule",
        "item_scope"
      ],
      "properties": {
        "read_root": {
          "type": "string",
          "pattern": "^src/poe_build_research/pob/corpus_data$"
        },
        "runtime_authority": {
          "type": "string",
          "const": "vendor/pob/source"
        },
        "consumer_rule": {
          "type": "string",
          "const": "Downstream agents must read committed corpus bundles instead of reparsing vendor/pob/source."
        },
        "item_scope": {
          "type": "string",
          "const": "items family contains base item records from src/Data/Bases/*.lua only."
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "source_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_path",
        "sha256",
        "size_bytes"
      ],
      "properties": {
        "source_path": {
          "type": "string",
          "pattern": "^vendor/pob/source/.+\\.lua$"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "canonical_path",
        "lock_path",
        "repo",
        "repo_url",
        "pinned_ref",
        "pinned_commit",
        "observed_commit",
        "tree_version"
      ],
      "properties": {
        "lane_id": {
          "type": "string",
          "const": "pob_source_lane"
        },
        "canonical_path": {
          "type": "string",
          "const": "vendor/pob/source"
        },
        "lock_path": {
          "type": "string",
          "const": "locks/pob.source.lock.json"
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "repo_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\\.git$"
        },
        "pinned_ref": {
          "type": "string",
          "pattern": "^refs/tags/v.+$"
        },
        "pinned_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "observed_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "tree_version": {
          "type": "string",
          "pattern": "^\\d+_\\d+(?:_[a-z]+(?:_[a-z]+)?)?$"
        }
      }
    },
    "family_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "relative_path",
        "record_count",
        "source_inputs"
      ],
      "properties": {
        "family": {
          "type": "string",
          "enum": [
            "items",
            "active_gems",
            "support_gems",
            "passives",
            "masteries",
            "ascendancies",
            "keystones",
            "config_surfaces"
          ]
        },
        "relative_path": {
          "type": "string",
          "pattern": "^src/poe_build_research/pob/corpus_data/[A-Za-z0-9_.-]+\\.json$"
        },
        "record_count": {
          "type": "integer",
          "minimum": 1
        },
        "source_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source_input"
          }
        }
      }
    }
  }
}
